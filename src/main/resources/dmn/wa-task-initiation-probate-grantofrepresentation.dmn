      <input id="InputClause_03i3ghi" label="evidenceHandled" biodi:width="291" camunda:inputVariable="evidenceHandled">
        <inputExpression id="LiteralExpression_0kx1xp4" typeRef="boolean">
          <text>if(additionalData != null and additionalData.Data != null and
            additionalData.Data.evidenceHandled
            != null) then
            additionalData.Data.evidenceHandled
            else
            false
